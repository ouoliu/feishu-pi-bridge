{
  "name": "feishu-pi-bridge",
  "version": "1.0.0",
  "description": "把飞书 / Lark 消息和本地 pi coding agent 打通的轻量 bot，一条命令起服务，在飞书里和 AI 编程助手对话",
  "type": "module",
  "bin": {
    "feishu-pi-bridge": "bin/feishu-pi-bridge.mjs"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@larksuiteoapi/node-sdk": "^1.66.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "feishu",
    "lark",
    "pi",
    "coding-agent",
    "bridge",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "package.json"
  ]
}
